  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "dev:functions": "cd functions && npm run build && firebase emulators:start --only functions,firestore",
    "dev:stripe": "echo 'Run: stripe listen --forward-to http://localhost:5001/ashutoshjainvi-ui/us-central1/stripeWebhook'",
